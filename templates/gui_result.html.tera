{% extends "base" %}

{% block title %}
pastor - gui result
{% endblock title %}

{% block content %}

<b>View file:</b> <pre><a href="/{{ id }}">https://{{ host }}/{{ id }}</a></pre> </br>
<b>Delete token:</b> <pre>{{ token }}</pre>
Curl: <pre>curl -X DELETE https://{{ host }}/{{ id }}?token={{ token }}</pre>
GET: <pre><a href="/delete/{{ id }}?token={{ token }}">https://{{ host }}/delete/{{ id }}?token={{ token }}</a></pre>

{% endblock content %}
