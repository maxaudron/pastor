{% extends "base" %}

{% block title %}
pastor - gui result
{% endblock title %}

{% block content %}

View file: <pre><a href="/{{ id }}">https://{{ host }}/{{ id }}</a></pre> </br>
Delete token: <pre>{{ token }}</pre> </br>
Curl: <pre>curl -X DELETE https://{{ host }}/{{ id }}?token={{ token }}</pre>

{% endblock content %}
